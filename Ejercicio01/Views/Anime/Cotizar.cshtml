@model Ejercicio01.Models.ClassCotizar
@{
    ViewBag.Title = "Sitio oficial de Catálogo de Animes";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";
}

<div class="page-container">
    <div class="card-anime">
        <h1 class="page-title">Cotiza tu anime favorito</h1>
        <p class="page-subtitle">
            Completa el formulario para calcular el precio de tu cotización.
        </p>

        <form asp-controller="Anime" asp-action="CalculoCotizar" method="post" class="form-grid">

            <div class="form-group">
                <label asp-for="Cliente" class="form-label">Cliente</label>
                <input asp-for="Cliente" class="form-input" placeholder="Ingrese su nombre" />
            </div>

            <div class="form-group">
                <label asp-for="Empresa" class="form-label">Empresa</label>
                <input asp-for="Empresa" class="form-input" placeholder="Ingrese su empresa" />
            </div>

            <div class="form-group">
                <label asp-for="Cantidad" class="form-label">Cantidad de animes</label>
                <input asp-for="Cantidad" class="form-input" placeholder="Ingrese la cantidad" />
            </div>

            <div class="form-group">
                <label asp-for="Canime" class="form-label">Elige tu anime</label>
                <select asp-for="Canime" class="form-select">
                    <option value="">Seleccione un anime</option>
                    <option value="Dragon01">DragonBall-V1</option>
                    <option value="Dragon02">DragonBall-V2</option>
                    <option value="Dragon03">DragonBall-V3</option>
                    <option value="Naruto01">Naruto-V1</option>
                    <option value="Naruto02">Naruto-V2</option>
                    <option value="Naruto03">Naruto-V3</option>
                    <option value="OnePiece01">OnePiece-V1</option>
                    <option value="OnePiece02">OnePiece-V2</option>
                    <option value="OnePiece03">OnePiece-V3</option>
                    <option value="OnePunch1">OnePunchMan-V1</option>
                    <option value="OnePunch2">OnePunchMan-V2</option>
                    <option value="OnePunch3">OnePunchMan-V3</option>
                </select>
            </div>

            <div class="actions-center">
                <input type="submit" value="Cotizar" class="btn-primary" />
            </div>

        </form>
    </div>
</div>