@model Ejercicio01.Models.ClassCotizar
@{
    ViewBag.Title = "sitio oficial de Catalogo de animes";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";
}
<h1 style="text-align:center">
    COTIZA TU ANIME FAVORITO !!!!!!!!!!
</h1>
<br />
<div class="row justify-content-center">
    <div class="cod-md-4">
        <form asp-controller="Anime"
              asp-action="CalculoCotizar">
            <br />

            <label>Cliente</label>
            <input asp-for="Cliente" class="form-control"
                   style="text-align:center" />
            <br />

            <label>Empresa</label>
            <input asp-for="Empresa" class="form-control"
                   style="text-align:center" />
            <br />

            <label>Cantidad de Animes</label>
            <input asp-for="Cantidad" class="form-control"
                   style="text-align:center" />
            <br />
            <label>elige tu Anime</label>
            <select asp-for="Canime">
                <option value="sel">
                    seleccione Anime

                </option>
                <option value="Dragon01">DragonBall-V1</option>
                <option value="Dragon02">DragonBall-V2</option>
                <option value="Dragon03">DragonBall-V3</option>
                <option value="Naruto01">Naruto-V1</option>
                <option value="Naruto02">Naruto-V2</option>
                <option value="Naruto03">Naruto-V3</option>
                <option value="OnePiece01">OnePiece-V1</option>
                <option value="OnePiece02">OnePiece-V2</option>
                <option value="OnePiece03">OnePiece-V3</option>
                <option value="OnePunch1">OnePunchMan-V1</option>
                <option value="OnePunch2">OnePunchMan-V2</option>
                <option value="OnePunch3">OnePunchMan-V3</option>
            </select>
            <br />
            <input type="submit" value="Cotizar" class="btn btn-warning" />

        </form>
    </div>
</div>