@model Ejercicio01.Models.ClassCotizar
@{
    ViewBag.Title = "Sitio oficial de Catalogo de Animes";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";
}

<div class="page-container">
    <div class="card-anime result-card">
        <h1 class="result-title">Cotización de Animes</h1>
        <p class="page-subtitle">Resumen de tu cotización generada correctamente</p>

        <div class="result-list">
            <div class="result-row">
                <span class="result-label">Cliente</span>
                <span class="result-value">@Model.Cliente</span>
            </div>

            <div class="result-row">
                <span class="result-label">Empresa</span>
                <span class="result-value">@Model.Empresa</span>
            </div>

            <div class="result-row">
                <span class="result-label">Tipo de Anime</span>
                <span class="result-value">@Model.Canime</span>
            </div>

            <div class="result-row">
                <span class="result-label">Precio</span>
                <span class="result-value">S/ @Model.Precio</span>
            </div>

            <div class="result-row">
                <span class="result-label">Cantidad</span>
                <span class="result-value">@Model.Cantidad</span>
            </div>

            <div class="result-row total-row">
                <span class="result-label">Total</span>
                <span class="result-value">S/ @Model.Total</span>
            </div>
        </div>

        <div class="actions-center">
            <a asp-controller="Anime" asp-action="Cotizar" class="btn-secondary">Nueva cotización</a>
        </div>

        <div class="extra-link">
            <a href="#">Ver listado de cotizaciones de animes</a>
        </div>
    </div>
</div>